/* pages/index/index.wxss */

/* 全局变量 */
page {
  --primary-color: #0ABAB5;
  --secondary-color: #8EE4AF;
  --bg-color: #F7FFFC;
  --card-bg: #ffffff;
  --text-main: #333333;
  --text-light: #666666;
  --border-color: #eeeeee;
  background-color: var(--bg-color);
}

/* 固定标题栏 */
.fixed-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 1000;
  box-sizing: border-box;
}

.header-left {
  display: flex;
  align-items: center;
}

.avatar {
  width: 66rpx;
  height: 66rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: rgba(255, 255, 255, 0.2);
}

.avatar image {
  width: 100%;
  height: 100%;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  white-space: nowrap;
  color: #0ABAB5;
}

.header-right {
  width: 66rpx;
  height: 66rpx;
}

/* 页面内容 */
.page-content {
  position: fixed;
  top: 110rpx;
  left: 0;
  right: 0;
  bottom: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  background-color: var(--bg-color);
  padding: 30rpx;
  box-sizing: border-box;
}

/* 表单项 */
.form-item {
  background-color: var(--card-bg);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

.form-item.error .input,
.form-item.error .picker {
  border-color: #ff4444;
}

.label {
  font-size: 30rpx;
  color: var(--text-main);
  display: block;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input {
  font-size: 30rpx;
  color: var(--text-light);
  padding: 16rpx 0;
  height:65rpx;
  width: 100%;
}

.picker {
  font-size: 30rpx;
  color: var(--text-light);
  padding: 16rpx 0;
}

.picker.placeholder {
  color: #999;
}

/* 行程活动多选样式 */
.checkbox-group {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 20rpx;
}

.activity-item {
  display: flex;
  align-items: center;
  background-color: var(--bg-color);
  padding: 12rpx 15rpx;
  border-radius: 15rpx;
  border: 1rpx solid var(--border-color);
  font-size: 28rpx;
  color: var(--text-light);
}

.activity-item checkbox {
  margin-right: 2rpx;
  transform: scale(0.8);
}

/* ========== 新增：智能生成选项样式 ========== */
.generate-options {
  background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 30rpx 0 20rpx;
  border: 2rpx solid rgba(10, 186, 181, 0.1);
  box-shadow: 0 8rpx 20rpx rgba(10, 186, 181, 0.08);
}

.options-title {
  font-size: 32rpx;
  color: var(--primary-color);
  margin-bottom: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
}

.options-title::before {
  content: '✨';
  margin-right: 10rpx;
  font-size: 36rpx;
}

.option-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid rgba(0, 0, 0, 0.05);
}

.option-item:last-child {
  border-bottom: none;
}

.option-info {
  display: flex;
  align-items: center;
  flex: 1;
  margin-right: 20rpx;
}

.option-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
  width: 60rpx;
  text-align: center;
}

.option-text {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.option-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 6rpx;
}

.option-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
}

/* 开关组件样式优化 */
switch {
  transform: scale(0.8);
  margin-right: -10rpx;
}

switch[checked] {
  color: var(--primary-color);
}

/* ========== 新增：加载状态提示样式 ========== */
.loading-status {
  background: linear-gradient(135deg, #e6f7f5 0%, #d1f0ec 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  margin: 20rpx 0;
  border: 2rpx solid var(--primary-color);
  box-shadow: 0 4rpx 12rpx rgba(10, 186, 181, 0.15);
}

.loading-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.loading-item:first-child {
  margin-bottom: 8rpx;
}

.loading-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  width: 60rpx;
  text-align: center;
  animation: pulse 1.5s ease-in-out infinite;
}

.loading-text {
  font-size: 28rpx;
  color: var(--primary-color);
  font-weight: 500;
  flex: 1;
}

/* ========== 新增：测试按钮样式（开发用） ========== */
.test-buttons {
  display: flex;
  gap: 20rpx;
  margin: 20rpx 0;
}

.test-btn {
  flex: 1;
  background-color: #f0f0f0;
  color: #666;
  font-size: 26rpx;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 35rpx;
  border: none;
  transition: all 0.3s ease;
}

.test-btn::after {
  border: none;
}

.test-btn:active {
  background-color: #e0e0e0;
  transform: scale(0.98);
}

.test-btn[disabled] {
  opacity: 0.5;
}

/* 提交按钮 */
.submit-btn {
  background: linear-gradient(135deg, var(--primary-color) 0%, #20c997 100%);
  color: white;
  border-radius: 50rpx;
  font-size: 34rpx;
  padding: 24rpx 0;
  margin-top: 40rpx;
  margin-bottom: 40rpx;
  border: none;
  width: 100%;
  font-weight: 600;
  box-shadow: 0 10rpx 20rpx rgba(10, 186, 181, 0.25);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  transform: scale(0.98);
  box-shadow: 0 5rpx 10rpx rgba(10, 186, 181, 0.3);
}

.submit-btn[disabled] {
  opacity: 0.7;
  transform: none;
  box-shadow: none;
  background: linear-gradient(135deg, #b0b0b0 0%, #909090 100%);
}

/* 侧栏样式 */
.sidebar-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1001;
  animation: fadeIn 0.3s ease;
}

.sidebar {
  position: fixed;
  top: 0;
  left: 0;
  bottom: 0;
  width: 560rpx;
  background-color: #ffffff;
  z-index: 1002;
  display: flex;
  flex-direction: column;
  animation: slideIn 0.3s ease;
  box-shadow: 2rpx 0 20rpx rgba(0, 0, 0, 0.1);
}

.sidebar-header {
  padding: 60rpx 40rpx;
  background: linear-gradient(135deg, #07c1a8, #6fc997);
  display: flex;
  align-items: center;
}

.sidebar-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 30rpx;
}

.sidebar-user-info {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 36rpx;
  font-weight: 500;
  color: #ffffff;
  margin-bottom: 6rpx;
}

.user-welcome {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.sidebar-menu {
  flex: 1;
  padding: 30rpx 0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 40rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.menu-item:active {
  background-color: var(--bg-color);
}

.menu-icon {
  font-size: 40rpx;
  width: 60rpx;
  margin-right: 30rpx;
  text-align: center;
}

.menu-text {
  font-size: 32rpx;
  color: var(--text-main);
}

.sidebar-footer {
  border-top: 2rpx solid var(--border-color);
  padding: 20rpx 0;
}

/* 微信登录按钮 */
.wechat-login-btn {
  display: flex;
  align-items: center;
  padding: 30rpx 40rpx;
  width: 100%;
  height: auto;
  line-height: normal;
  background-color: transparent;
  border: none;
  border-radius: 0;
  text-align: left;
  font-size: 32rpx;
  color: var(--text-main);
  border-bottom: 1rpx solid var(--border-color);
}

.wechat-login-btn::after {
  border: none;
}

.wechat-login-btn:active {
  background-color: var(--bg-color);
}

.wechat-login-btn .menu-icon {
  font-size: 40rpx;
  width: 60rpx;
  margin-right: 30rpx;
  text-align: center;
}

.wechat-login-btn .menu-text {
  font-size: 32rpx;
  color: var(--text-main);
}

/* 登录表单样式 - 简化版 */
.login-form {
  padding: 30rpx 40rpx;
}

.login-input {
  border: 1rpx solid #e0e0e0;
  padding: 24rpx 20rpx;
  margin: 20rpx 0;
  border-radius: 12rpx;
  background-color: #f8f8f8;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.login-input:focus {
  border-color: var(--primary-color);
  background-color: #ffffff;
}

.login-btn {
  background-color: var(--primary-color);
  color: #ffffff;
  margin: 30rpx 0 20rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-weight: 500;
  border: none;
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  opacity: 0.8;
}

.register-toggle {
  text-align: center;
  color: var(--primary-color);
  padding: 20rpx;
  font-size: 28rpx;
}

.register-toggle:active {
  opacity: 0.7;
}

/* 动画 */
@keyframes slideIn {
  from { transform: translateX(-100%); }
  to { transform: translateX(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* 新增：脉冲动画 */
@keyframes pulse {
  0% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.6;
    transform: scale(1.1);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

/* 滚动条样式 */
.page-content::-webkit-scrollbar {
  width: 0;
  background: transparent;
}