/* 固定标题栏 */
.fixed-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 1000;
  box-sizing: border-box;
}

.header-right {
  position: absolute;
  right: 30rpx;
  top: 45rpx;
  display: flex;
  align-items: center;
}

/* 容器 */
.container {
  padding: 30rpx;
  background-color: var(--bg-color);
  min-height: 100vh;
}

/* 信息卡片 */
.info-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.info-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.info-item {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 24rpx;
  line-height: 1.5;
}

/* 行李清单标题 */
.luggage-title {
  display: flex;
  align-items: center;
  padding: 40rpx 0 24rpx 0;
  margin-top: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.title-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.title-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  flex: 1;
}

.title-count {
  font-size: 30rpx;
  color: rgb(105, 128, 128);
  background-color: #c8eceb;
  padding: 10rpx 28rpx;
  border-radius: 50rpx;
}

/* 分类容器 */
.category {
  margin-bottom: 50rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.category:last-child {
  margin-bottom: 30rpx;
}

/* 分类标题容器 */
.category-title-container {
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
  min-height: 70rpx;
  display: flex;
  align-items: center;
}

.category-title-container:active {
  background-color: #f5f5f5;
  border-radius: 12rpx;
}

.category-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  display: block;
  width: 100%;
}

.category-title-input {
  width: 100%;
  font-size: 34rpx;
  font-weight: 600;
  padding: 12rpx 0;
  background-color: #ffffff;
}

/* 分类内的物品列表 */
.category-items {
  margin-bottom: 20rpx;
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  min-height: 90rpx;
}

.list-item:active {
  background-color: #f5f5f5;
  border-radius: 12rpx;
}

.list-item:last-child {
  border-bottom: none;
}

/* 复选框区域 */
.list-item checkbox {
  margin-right: 24rpx;
  transform: scale(1.1);
  padding: 10rpx;
}

/* 物品名称 */
.goods-name {
  font-size: 32rpx;
  color: #333;
  flex: 1;
  padding: 12rpx 0;
  line-height: 1.4;
}

/* ===== 统一物品输入框样式 ===== */
.item-edit-input {
  flex: 1;
  font-size: 32rpx;
  color: #000000;
  padding: 16rpx 0;
  margin-left: 16rpx;
  background-color: #ffffff;
}

.item-edit-input::placeholder {
  color: #aeb3af;
  font-size: 100rpx;
}

/* 新物品输入行 */
.list-item.new-item {
  background-color: #f9fff9;
  border-left: 6rpx solid #abe2d4;
  padding-left: 24rpx;
  margin-top: 8rpx;
  margin-bottom: 8rpx;
  border-radius: 12rpx;
  height: 100rpx;
  font-size: 100rpx;
}

/* 分类底部添加按钮 */
.category-footer {
  margin-top: 30rpx;
  padding-top: 24rpx;
  border-top: 2rpx dashed #e0e0e0;
}

.add-item-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  background-color: #d4f0ec;
  border-radius: 16rpx;
  border: 2rpx solid #9ed3c0;
  transition: all 0.2s;
}

.add-item-btn:active {
  background-color: #c0e8d0;
  border-color: #188050;
  transform: scale(0.98);
}

.add-icon {
  font-size: 36rpx;
  color: #20a070;
  margin-right: 16rpx;
  font-weight: bold;
}

.add-text {
  font-size: 30rpx;
  color: #467a72;
  font-weight: 500;
}

/*底部按钮*/
.btn-group {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}
.save-btn {
  flex: 1;
  background-color: var(--primary-color);
  color: white;
  border-radius: 50rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
  border: none;
}
.share-btn {
  flex: 1;
  background-color: var(--secondary-color);
  color: white;
  border-radius: 50rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
  border: none;
}
.back-btn {
  flex: 1;
  background-color: var(--card-bg);
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
  border-radius: 50rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
}