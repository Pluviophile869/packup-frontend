<view class="fixed-header">
  <!-- 行李清单标题 -->
  <view class="luggage-title">
    <text class="title-icon">🧳</text>
    <text class="title-text">行李清单</text>
    <view class="header-right">
      <text class="title-count">{{totalItems}}件物品</text>
    </view>
    
  </view>
</view>

<view class="container">
  <!-- 分类行李清单 -->
  <view class="list-container">
    <view class="category" wx:for="{{listCategories}}" wx:key="title" wx:for-index="categoryIndex">
      <!-- 分类标题 - 点击整行编辑 -->
      <view class="category-title-container" bindtap="startEditCategory" data-category="{{categoryIndex}}">
        <block wx:if="{{editingCategory === categoryIndex}}">
          <input 
            class="category-title-input" 
            value="{{item.title}}" 
            bindinput="onCategoryTitleInput" 
            bindblur="saveCategoryTitle" 
            data-category="{{categoryIndex}}"
            auto-focus
            catchtap="stopPropagation"
          />
        </block>
        <block wx:else>
          <text class="category-title">{{item.title}}</text>
        </block>
      </view>
      
      <!-- 分类内的物品列表 -->
      <view class="category-items">
        <!-- 现有的物品列表 -->
        <view class="list-item" 
              wx:for="{{item.items}}" 
              wx:for-item="goods" 
              wx:key="name" 
              wx:for-index="itemIndex">
          
          <checkbox checked="{{goods.checked}}" color="{{secondaryColor}}" bindchange="toggleItem" 
                   data-category="{{categoryIndex}}" data-index="{{itemIndex}}" 
                   catchtap="stopPropagation" />
          
          <!-- 物品名称：编辑状态或显示状态 -->
          <block wx:if="{{editingItem && editingItem.category === categoryIndex && editingItem.index === itemIndex}}">
            <input 
              class="item-edit-input" 
              value="{{goods.name}}" 
              bindinput="onItemNameInput" 
              bindblur="saveItemName" 
              data-category="{{categoryIndex}}" 
              data-index="{{itemIndex}}"
              auto-focus
              catchtap="stopPropagation"
            />
          </block>
          <block wx:else>
            <text class="goods-name {{goods.checked ? 'checked' : ''}}" 
                  bindtap="startEditItem" 
                  data-category="{{categoryIndex}}" 
                  data-index="{{itemIndex}}">{{goods.name}}</text>
          </block>
        </view>
        
        <!-- 新添加的物品输入框 -->
        <view class="list-item new-item" wx:if="{{newItemCategory === categoryIndex}}">
          <checkbox color="{{secondaryColor}}" disabled />
          <input 
            class="item-edit-input" 
            value="{{newItemValue}}"
            bindinput="onNewItemInput"
            bindblur="saveNewItem"
            data-category="{{categoryIndex}}"
            auto-focus
            catchtap="stopPropagation"
          />
        </view>
      </view>
      
      <!-- 分类底部添加按钮 -->
      <view class="category-footer">
        <view class="add-item-btn" bindtap="addNewItem" data-category="{{categoryIndex}}">
          <text class="add-text">添加{{item.title}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="btn-group">
    <button class="share-btn" open-type="share">分享清单</button>
  </view>
</view>