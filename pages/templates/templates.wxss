/* templates.wxss */

/* 头部导航 */
.header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background-color: #ffffff;
  border-bottom: 2rpx solid #f0f0f0;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.back-icon {
  font-size: 40rpx;
  color: #333;
}

.title {
  flex: 1;
  font-size: 36rpx;
  font-weight: 500;
  color: #333;
}

.add-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 50rpx;
  color: #43b3af;
  line-height: 1;
}

/* ===== 标签栏样式 ===== */
.tabs-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #ffffff;
  border-bottom: 2rpx solid #f0f0f0;
  z-index: 999;
  display: flex;
  align-items: center;
  padding-left: 0;
  padding-right: 100rpx;
}

/* 可滚动标签区域 */
.tabs-scroll {
  height: 100%;
  white-space: nowrap;
  flex: 1;
}

.tabs-wrapper {
  display: inline-flex;
  align-items: center;
  height: 100%;
  padding: 0 20rpx;
  gap: 20rpx;
}

/* 标签项样式 */
.tab-item {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 30rpx;
  background-color: #dafaef;
  border-radius: 50rpx;
  font-size: 28rpx;
  color: rgb(69, 112, 105);
  transition: all 0.2s;
  position: relative;
}

.tab-item.active {
  background-color: #48c4bf;
  color: #ffffff;
}

/* 自定义标签 */
.tab-item.custom-tab {
  padding: 0;
  overflow: hidden;
}

.tab-content {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 0 16rpx 30rpx;
  height: 100%;
}

.tab-close {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  margin: 0 10rpx;
  background-color: rgba(0, 0, 0, 0.1);
  border-radius: 50%;
  font-size: 24rpx;
  color: #666;
  transition: all 0.2s;
}

.tab-close:active {
  background-color: #ff4d4f;
  color: #ffffff;
}

.tab-item.active .tab-close {
  background-color: rgba(255, 255, 255, 0.3);
  color: #ffffff;
}

/* 固定加号按钮 */
.fixed-add-tab {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 70rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #d5f3f2;
  color: #148d89;
  border: 2rpx dashed #48c4bf;
  border-radius: 50rpx;
  z-index: 1000;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.fixed-add-tab .add-icon {
  font-size: 50rpx;
  font-weight: bold;
  line-height: 1;
}

/* 页面内容 */
.page-content {
  position: fixed;
  top: 100rpx;
  left: 0;
  right: 0;
  bottom: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  background-color: #F7FFFC;
  padding: 30rpx;
  box-sizing: border-box;
}

/* 行程卡片 */
.trip-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.trip-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.trip-info {
  flex: 1;
}

.trip-name {
  font-size: 34rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.trip-desc {
  font-size: 26rpx;
  color: #999;
  display: block;
}

.trip-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: #f5f5f5;
}

.action-icon {
  font-size: 28rpx;
}

.edit-btn .action-icon {
  color: #07c160;
}

.delete-btn .action-icon {
  color: #ff4d4f;
}

/* 标签 */
.trip-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.tag {
  background-color: #f0f9f0;
  color: #07c160;
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
}

/* 元信息 */
.trip-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.meta-item {
  font-size: 26rpx;
  color: #666;
}

/* 日期信息 */
.trip-dates {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.date-item {
  font-size: 26rpx;
  color: #48c4bf;
  background-color: #f0f9f9;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
}

/* 卡片底部 - 标签展示 */
.trip-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.footer-tags {
  flex: 1;
  margin-right: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

/* 底部标签样式 - 与顶部的标签栏 tab-item 样式完全一致 */
.footer-tag-text {
  display: inline-block;
  padding: 10rpx 20rpx;
  background-color: #dafaef;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: rgb(69, 112, 105);
  white-space: nowrap;
  transition: all 0.2s;
}

/* 悬停效果 - 与 tab-item 一致 */
.footer-tag-text:active {
  opacity: 0.8;
  transform: scale(0.96);
}

.footer-tag-empty {
  font-size: 28rpx;
  color: #999;
  font-style: italic;
  padding: 16rpx 0;
}

.use-btn {
  background-color: #48c4bf;
  color: #fff;
  font-size: 30rpx;
  padding: 12rpx 30rpx;
  border-radius: 50rpx;
  white-space: nowrap;
}

.use-btn text {
  color: #fff;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-image {
  width: 300rpx;
  height: 300rpx;
  margin-bottom: 40rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.create-btn {
  background-color: #0ABAB5;
  color: #fff;
  width: 300rpx;
  border-radius: 35rpx;
  height: 90rpx;
  font-size: 50rpx;
  padding: 8rpx 0;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1001;
}

.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 700rpx;
  max-height: 80vh;
  background-color: #fff;
  border-radius: 24rpx;
  z-index: 1002;
  display: flex;
  flex-direction: column;
}

.modal-content.small {
  width: 500rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 30rpx;
}

.modal-footer {
  display: flex;
  padding: 30rpx;
  gap: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.modal-footer button {
  flex: 1;
  margin: 0;
  font-size: 28rpx;
  border-radius: 50rpx;
  height: 80rpx;
  line-height: 80rpx;
}

.cancel-btn {
  background-color: #f5f5f5;
  color: #666;
}

.confirm-btn {
  background-color: #48c4bf;
  color: #fff;
}

/* 表单样式 */
.form-item {
  margin-bottom: 30rpx;
  width: 90%;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.half {
  flex: 1;
}

.label {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.required {
  color: #ff4d4f;
  margin-left: 4rpx;
}

.input {
  font-size: 28rpx;
  color: #333;
  width: 90%;
  height: 80rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.picker {
  font-size: 28rpx;
  color: #333;
  height: 80rpx;
  line-height: 80rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  background-color: #fff;
  width: 90%;
  box-sizing: border-box;
}

.tags-tip {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

/* ===== 标签选择器样式 - 无背景无边框 ===== */
.tags-selector-container {
  background-color: transparent;
  padding: 0;
}

/* 已选标签区域 - 无背景无边框 */
.selected-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
  background-color: transparent;
  border-bottom: none;
  padding-bottom: 0;
}

.selected-tag {
  display: flex;
  align-items: center;
  background-color: transparent;
  padding: 4rpx 8rpx;
}

.selected-tag-text {
  font-size: 26rpx;
  color: #48c4bf;
  margin-right: 6rpx;
}

.selected-tag-remove {
  font-size: 20rpx;
  color: #999;
  width: 28rpx;
  height: 28rpx;
  line-height: 28rpx;
  text-align: center;
  background-color: transparent;
  border-radius: 50%;
}

.selected-tag-remove:active {
  color: #ff4d4f;
}

/* 可选标签列表 - 无背景无边框 */
.tags-list {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  background-color: transparent;
}

/* 可选择的标签样式 - 点击变深色 */
.tag-selectable {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  font-size: 26rpx;
  color: rgb(69, 112, 105); 
  background-color: #dafaef;
  border: none;
  border-radius: 20rpx;
  transition: all 0.2s;
  cursor: pointer;
}

/* 选中状态 - 深色 */
.tag-selectable.selected {
  background-color: #48c4bf;
  color: rgb(255, 255, 255);
  font-weight: 500;
}

.tagSelectable:active {
  opacity: 0.6;
}

/* 添加标签小按钮 */
.add-tag-btn-small {
  width: 70rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #d5f3f2;
  color: #148d89;
  border: 2rpx dashed #48c4bf;
  border-radius: 50rpx;
  z-index: 1000;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.add-tag-btn-small .add-icon-small {
  font-size: 36rpx;
  color: #48c4bf;
  line-height: 1;
}

.add-tag-btn-small:active {
  opacity: 0.6;
}

/* 自定义标签项 - 如果需要删除按钮 */
.custom-tag-item {
  padding-right: 18rpx;
  display: inline-flex;
  align-items: center;
}

/* 标签删除按钮 - 极简风格 */
.tag-delete-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-left: 4rpx;
  width: 26rpx;
  height: 26rpx;
  background-color: transparent;
  border-radius: 0;
  cursor: pointer;
  transition: all 0.2s;
}

.tag-delete-btn:active {
  opacity: 0.6;
}

.tag-delete-icon {
  font-size: 18rpx;
  color: #999;
  line-height: 1;
}

.selected .tag-delete-icon {
  color: #ff4d4f;
}

/* 添加新标签区域 - 极简风格 */
.add-tag-input-container {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 10rpx;
  background-color: transparent;
}

.add-tag-input {
  flex: 1;
  height: 60rpx;
  background-color: transparent;
  border-radius: 0;
  padding: 0 0 0 8rpx;
  font-size: 26rpx;
  border: none;
  border-bottom: 2rpx solid #e0e0e0;
}

.add-tag-input:focus {
  border-bottom-color: #48c4bf;
}

.add-tag-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: transparent;
  border-radius: 0;
  padding: 0 8rpx;
  height: 60rpx;
  cursor: pointer;
  transition: all 0.2s;
}

.add-tag-btn:active {
  opacity: 0.6;
}

.add-tag-btn-icon {
  font-size: 26rpx;
  color: #48c4bf;
  margin-right: 2rpx;
}

.add-tag-btn-text {
  font-size: 24rpx;
  color: #48c4bf;
}

/* 删除按钮悬停效果 */
.delete-hover {
  background-color: #7aece7;
  color: #fff;
}